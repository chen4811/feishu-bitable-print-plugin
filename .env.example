# 数据库配置
DATABASE_URL=postgresql://username:password@localhost:5432/print_plugin_db

# 飞书应用配置
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_REDIRECT_URI=http://localhost:5000/api/auth/feishu/callback

# JWT 密钥（用于用户登录会话）
JWT_SECRET=your_jwt_secret_key_here

# 加密密钥（用于加密存储授权码，32字节，64个十六进制字符）
# 可以使用以下命令生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# Next.js 配置
NEXT_PUBLIC_APP_URL=http://localhost:5000
